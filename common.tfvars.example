# Shared values used by both bootstrap/ and app/
# Copy this file to common.tfvars and fill in your values.
# Pass it explicitly when running plan/apply:
#   terraform plan  -var-file=../common.tfvars -var-file=terraform.tfvars
#   terraform apply -var-file=../common.tfvars -var-file=terraform.tfvars

location = "westeurope"

tags = {
  owner  = "your.name@example.com"
  course = "cloud-devops"
}
