# App-specific values - copy to terraform.tfvars and fill in your values.
# Shared values (subscription_id, location, tags) come from ../common.tfvars.

resource_group_name = "clouddevops-app-rg"

# Base names - a random suffix is appended for global uniqueness.
# Storage: lowercase, base <= 19 chars (result must stay within 24).
storage_account_name  = "samkessprojimages"
images_container_name = "images"

app_service_plan_name = "clouddevops-app-plan"

# Base name; the result becomes <name>-<suffix>.azurewebsites.net.
app_service_name = "samkessproj-app"

# F1 = free (sleeps when idle, 60 CPU-min/day). B1 (~€13/mo) for always-on.
app_service_sku = "F1"

# Object ID of the clouddevops-deployers AD group, created by the agent layer.
# Get it with: cd ../agent && terraform output -raw deployers_group_object_id
# (The infra pipeline supplies this as the deployersGroupObjectId variable.)
deployers_group_object_id = "00000000-0000-0000-0000-000000000000"
