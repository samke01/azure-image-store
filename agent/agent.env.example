# Build agent configuration. Copy to agent.env and fill in:
#   cp agent.env.example agent.env
# agent.env is gitignored because AZP_TOKEN is a secret. Never commit it.

# Your Azure DevOps organization URL.
AZP_URL=https://dev.azure.com/your-org

# Agent pool the pipeline targets. Must match `pool: name:` in azure-pipelines.yml.
AZP_POOL=clouddevops-agents

# Azure DevOps Personal Access Token, scope: Agent Pools (Read & manage).
# Used only once, at registration. Carries no Azure RBAC. Never commit it.
AZP_TOKEN=

# Optional. Defaults to "<hostname>-agent" if left blank.
AZP_AGENT_NAME=

# Optional. Overrides the pinned default agent version in setup-agent.sh.
AZP_AGENT_VERSION=

# Optional. Linux user the agent service runs as. Matches admin_username in app/vm.tf.
AGENT_USER=azureuser
